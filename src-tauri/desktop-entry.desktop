[Desktop Entry]
Categories={{categories}}
{{#if comment}}
Comment={{comment}}
{{/if}}
Exec={{exec}}
StartupWMClass={{exec}}
Icon={{icon}}
Name={{name}}
Terminal=false
Type=Application
Actions=NewWindow;
{{#if mime_type}}
MimeType={{mime_type}}
{{/if}}

[Desktop Action NewWindow]
Name=New Window
Exec={{exec}} --new-window
